@model IEnumerable<LibraryManagementSystem.Models.Book>

@{
    ViewData["title"] = "Book List";
}

<h2>Book List</h2>
<p>Welcome to Library Management system</p>

    <p>
        <a asp-action= "Create" class="btn btn-primary"> Add New Books</a>
    </p>

<table class="table table-bordered table-striped text-center">
    <thead>
        <tr class ="text-center">
            <th>Title</th>
            <th>ISBN</th>
            <th>Total Copies</th>
            <th>Available Copies</th>
            <th>Category</th>
            <th>Author</th>
            <th>Publisher</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.ISBN</td>
            <td>@item.TotalCopies</td>
            <td>@item.AvailableCopies</td>
            <td>@item.Category?.Name</td>
            <td>@item.Author?.Name</td>
            <td>@item.Publisher?.Name</td>

      <!-- Edit Function............ --> 
        <td class="text-center">
            <a asp-action="Edit"
                asp-route-id="@item.Id"
                class="btn btn-warning btn-sm">
                Edit
            </a>
        </td>
        </tr>
    }
    </tbody>
</table>
    

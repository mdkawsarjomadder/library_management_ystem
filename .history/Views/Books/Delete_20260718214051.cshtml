
@model LibraryManagementSystem.Models.Book
@{
     ViewData["Title"] ="Delete Book";
}

    <h1 class="mb-4">
       <i class="bi bi-trash-fill text-danger"></i>
       Delete Book
    </h1>

    <h4 class="text-danger">
        Are you sure you want to delete this book?
    </h4>
        <hr>
     <dl class="row">
        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">ISBN</dt>
        <dd class="col-sm-9">@Model.ISBN</dd>

        <dt class="col-sm-3">Total Copies</dt>
        <dd class="col-sm-9">@Model.TotalCopies</dd>

        <dt class="col-sm-3">Available Copies</dt>
        <dd class="col-sm-9">@Model.AvailableCopies</dd>

        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@Model.Category?.Name</dd>

        <dt class="col-sm-3">Author</dt>
        <dd class="col-sm-9">@Model.Author?.Name</dd>

        <dt class="col-sm-3">Publisher</dt>
        <dd class="col-sm-9">@Model.Publisher?.Name</dd>



     </dl>
    
    <form asp-action="Delete" method="post">
        <input asp-for="Id" type="hidden" />

        <button type="submit" class="btn btn-danger">
            Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Back To List
        </a>


    </form>
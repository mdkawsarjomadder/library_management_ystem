
@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = "Details";
}

<h1>@ViewData["Title"]</h1>


         <div class="card shadow ">
            <div class="card header bg-primary text-white">
                <h3 class="mb-0 ms-5">
                    <i class="bi bi-book"></i>
                      Book Datails
                </h3>
             </div>

              @*book list start*@ 
                   <div class="card body ms-5"> 
                       <div class="row mb-3">
                           <div class="col-md-3 fw-bold">Title</div>
                           <div class="col-md-6"> :@Model.Title</div>
                       </div>
                       <div class="row mb-3">
                           <div class="col-md-3 fw-bold">Author</div>
                           <div class="col-md-6"> : @Model.Author?.Name</div>
                       </div>
                       <div class="row mb-3">
                           <div class="col-md-3 fw-bold">Title</div>
                           <div class="col-md-6"> :@Model.Category?.Name</div>
                       </div>
                       <div class="row mb-3">
                           <div class="col-md-3 fw-bold">Title</div>
                           <div class="col-md-6"> :@Model.Publisher?.Name</div>
                       </div>
                       <div class="row mb-3">
                           <div class="col-md-3 fw-bold">Total Copies</div>
                           <div class="col-md-6"> :@Model.TotalCopies</div>
                       </div>
                       <div class="row mb-3">
                           <div class="col-md-3 fw-bold">Available Copies</div>
                           <div class="col-md-6"> :@Model.AvailableCopies</div>
                       </div>
                   </div>   

                       <div class="mt-4">
                           <a asp-action="Index" 
                              asp-route-id="@Model.Id"
                              class="btn btn-warning" >
                                <i class="bi bi-pencil-square"></i>
                                 Edit
                              </a>

                              <a asp-action="Index" 
                              asp-route-id="@Model.Id"
                              class="btn btn-secondary">
                               <i class="bi bi-arrow-left"></i>
                                 Back
                              </a>
                       </div>

 
          </div>
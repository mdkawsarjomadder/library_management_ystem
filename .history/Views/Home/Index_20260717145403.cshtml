  @model IEnumerable<LibraryManagementSystem.Models.Borrow>
    @{
        ViewData["Title"] = "Dashboard";
    }  



<!-- ================= Dashboard Header ================= -->

<div class="mb-4">

    <h2 class="fw-bold">
        📚 Library Management Dashboard
    </h2>

    <p class="text-muted fs-5 mb-3 ms-5">
        Welcome to the Library Management Dashboard
    </p>

</div>

<!-- ================= Quick Actions ================= -->

<div class="d-flex flex-wrap gap-2 mb-4">

    <a asp-controller="Books"
       asp-action="Create"
       class="btn btn-primary">

        ➕ Add Book

    </a>

    <a asp-controller="Members"
       asp-action="Create"
       class="btn btn-success">

        👤 Add Member

    </a>

    <a asp-controller="Borrows"
       asp-action="Create"
       class="btn btn-warning text-dark">

        📚 Borrow Book

    </a>

    <a asp-controller="Borrows"
       asp-action="Index"
       class="btn btn-info text-white">

        📖 View Borrows

    </a>

</div>

<!-- ================= Statistics Cards ================= -->

<div class="row g-4">

    <!-- Total Books -->

    <div class="col-lg-4 col-md-6">

        <div class="card bg-primary text-white dashboard-card shadow-sm border-0 h-100">

            <div class="card-body text-center py-4">

                <i class="bi bi-book dashboard-icon"></i>

                <h5 class="mt-3 fw-bold">
                    Total Books
                </h5>

                <h2 class="display-5 fw-bold">
                    @ViewBag.TotalBooks
                </h2>

            </div>

        </div>

    </div>

    <!-- Members -->

    <div class="col-lg-4 col-md-6">

        <div class="card bg-success text-white dashboard-card shadow-sm border-0 h-100">

            <div class="card-body text-center py-4">

                <i class="bi bi-people-fill dashboard-icon"></i>

                <h5 class="mt-3 fw-bold">
                    Total Members
                </h5>

                <h2 class="display-5 fw-bold">
                    @ViewBag.TotalMembers
                </h2>

            </div>

        </div>

    </div>

    <!-- Borrowed -->

    <div class="col-lg-4 col-md-6">

        <div class="card bg-info text-white dashboard-card shadow-sm border-0 h-100">

            <div class="card-body text-center py-4">

                <i class="bi bi-arrow-left-right dashboard-icon"></i>

                <h5 class="mt-3 fw-bold">
                    Borrowed Books
                </h5>

                <h2 class="display-5 fw-bold">
                    @ViewBag.TotalBorrowed
                </h2>

            </div>

        </div>

    </div>

    <!-- Returned -->

    <div class="col-lg-4 col-md-6">

        <div class="card bg-danger text-white dashboard-card shadow-sm border-0 h-100">

            <div class="card-body text-center py-4">

                <i class="bi bi-check-circle dashboard-icon"></i>

                <h5 class="mt-3 fw-bold">
                    Returned Books
                </h5>

                <h2 class="display-5 fw-bold">
                    @ViewBag.TotalReturned
                </h2>

            </div>

        </div>

    </div>

    <!-- OverDue -->

    <div class="col-lg-4 col-md-6">

        <div class="card bg-warning text-dark dashboard-card shadow-sm border-0 h-100">

            <div class="card-body text-center py-4">

                <i class="bi bi-exclamation-triangle dashboard-icon"></i>

                <h5 class="mt-3 fw-bold">
                    Total OverDue
                </h5>

                <h2 class="display-5 fw-bold">
                    @ViewBag.TotalOverDue
                </h2>

            </div>

        </div>

    </div>

    <!-- Available -->

    <div class="col-lg-4 col-md-6">

        <div class="card bg-secondary text-white dashboard-card shadow-sm border-0 h-100">

            <div class="card-body text-center py-4">

                <i class="bi bi-book-half dashboard-icon"></i>

                <h5 class="mt-3 fw-bold">
                    Available Books
                </h5>

                <h2 class="display-5 fw-bold">
                    @ViewBag.AvailableBooks
                </h2>

            </div>

        </div>

    </div>

</div>

<hr class="my-4">

<!-- ================= Library Statistics ================= -->

<div class="card shadow-sm border-0 mb-4">

    <div class="card-header bg-dark text-white">

        <h5 class="mb-0">
            📊 Library Statistics
        </h5>

    </div>

    <div class="card-body">

        <div style="height:320px">

            <canvas id="ChartBorrowed"></canvas>

        </div>

    </div>

</div>

<!-- ================= Recent Borrow History ================= -->

<h4 class="fw-bold mb-3">

    📋 Recent Borrow History

</h4>

<div class="table-responsive shadow-sm rounded overflow-hidden">

    <table class="table table-hover table-striped table-bordered align-middle text-center mb-0">

        <thead class="table-dark">

            <tr>

                <th>Book</th>
                <th>Member</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Status</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {

                <tr>

                    <td>

                        @item.Book?.Title

                    </td>

                    <td>

                        @item.Member?.Name

                    </td>

                    <td>

                        @item.BorrowDate.ToString("dd MMM yyyy")

                    </td>

                    <td>

                        @item.DueDate.ToString("dd MMM yyyy")

                    </td>

                    <td>

                        @if (item.ReturnDate != null)
                        {

                            <span class="badge bg-success">

                                Returned

                            </span>

                        }
                        else if (item.DueDate < DateTime.Today)
                        {

                            <span class="badge bg-danger">

                                OverDue

                            </span>

                        }
                        else
                        {

                            <span class="badge bg-warning text-dark">

                                Borrowed

                            </span>

                        }

                    </td>

                </tr>

            }

        </tbody>

    </table>

</div>

<!-- ================= View All ================= -->

<div class="text-end mt-3">

    <a asp-controller="Borrows"
       asp-action="Index"
       class="btn btn-outline-primary">

        📖 View All Borrows →

    </a>

</div>



@section Scripts{

<script>

const ctx = document.getElementById('ChartBorrowed');

new Chart(ctx, {

    type: 'bar',

    data: {

        labels: [
            'Borrowed',
            'Returned',
            'OverDue'
        ],

        datasets: [{

            label: 'Library Statistics',

            data: [

                @ViewBag.ChartBorrowed,
                @ViewBag.ChartReturned,
                @ViewBag.ChartOverDue

            ],

            backgroundColor: [

                '#0d6efd',   // Blue
                '#198754',   // Green
                '#dc3545'    // Red

            ],

            borderColor: [

                '#0d6efd',
                '#198754',
                '#dc3545'

            ],

            borderWidth: 1,

            borderRadius: 10,

            borderSkipped: false,

            maxBarThickness: 28

        }]

    },

    options: {

        responsive: true,

        maintainAspectRatio: false,

        animation: {

            duration: 1500,

            easing: 'easeOutQuart'

        },

        plugins: {

            legend: {

                display: false

            },

            tooltip: {

                backgroundColor: '#212529',

                titleColor: '#fff',

                bodyColor: '#fff',

                cornerRadius: 8,

                padding: 10

            }

        },

        scales: {

            x: {

                ticks: {

                    color: '#495057',

                    font: {

                        size: 14,

                        weight: 'bold'

                    }

                },

                grid: {

                    color: 'rgba(0,0,0,.05)',

                    lineWidth: 0.5,

                    drawBorder: false

                }

            },

            y: {

                beginAtZero: true,

                ticks: {

                    stepSize: 2,

                    color: '#495057',

                    font: {

                        size: 13

                    }

                },

                grid: {

                    color: 'rgba(0,0,0,.05)',

                    lineWidth: 0.5,

                    drawBorder: false

                }

            }

        }

    }

});

</script>

}





















